{
  "name": "laika",
  "displayName": "Laika",
  "description": "A visual explorer for .http files",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:laikaHttpFiles"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laika",
          "title": "Laika",
          "icon": "media/laika.svg"
        }
      ]
    },
    "views": {
      "laika": [
        {
          "id": "laikaHttpFiles",
          "name": "HTTP Files"
        }
      ]
    },
    "commands": [
      {
        "command": "laika.refreshFiles",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "laika.sendRequest",
        "title": "Send Request",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "laika.refreshFiles",
          "when": "view == laikaHttpFiles",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "laika.sendRequest",
          "when": "view == laikaHttpFiles && viewItem == request",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "semantic-release": "^24.2.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
