{
  "name": "laika",
  "displayName": "Laika",
  "description": "A visual explorer for .http files",
  "version": "0.1.0-beta",
  "publisher": "kimdim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lfmundim/laika.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
"main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laika",
          "title": "Laika",
          "icon": "media/laika.png"
        }
      ]
    },
    "views": {
      "laika": [
        {
          "id": "laikaHttpFiles",
          "name": "HTTP Files"
        },
        {
          "id": "laikaHistory",
          "name": "History"
        }
      ]
    },
    "commands": [
      {
        "command": "laika.refreshFiles",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "laika.sendRequest",
        "title": "Send Request",
        "icon": "$(play)"
      },
      {
        "command": "laika.selectEnvironment",
        "title": "Select Environment",
        "icon": "$(server-environment)"
      },
      {
        "command": "laika.clearHistory",
        "title": "Clear History",
        "icon": "$(trash)"
      },
      {
        "command": "laika.showHistoryEntry",
        "title": "Show History Entry"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "laika.refreshFiles",
          "when": "view == laikaHttpFiles",
          "group": "navigation"
        },
        {
          "command": "laika.selectEnvironment",
          "when": "view == laikaHttpFiles",
          "group": "navigation"
        },
        {
          "command": "laika.clearHistory",
          "when": "view == laikaHistory",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "laika.sendRequest",
          "when": "view == laikaHttpFiles && viewItem == request",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "mocha 'out/test/**/*.test.js'",
    "test:coverage": "c8 mocha 'out/test/**/*.test.js'",
    "coverage:report": "c8 report --reporter=text --reporter=html --reporter=lcov"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "mocha": "^10.7.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "nerdbank-gitversioning": "^3.9.50",
    "npm-run-all": "^4.1.5",
    "c8": "^9.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
