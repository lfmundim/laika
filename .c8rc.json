{
  "all": true,
  "include": [
    "out/**/*.js"
  ],
  "exclude": [
    "out/test/**",
    "out/extension.js",
    "out/**/*.d.ts",
    "node_modules/**"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json"
  ],
  "temp-dir": "./.c8_temp",
  "report-dir": "./coverage",
  "branches": 70,
  "lines": 70,
  "functions": 70,
  "statements": 70
}
